{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node (Express API)",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "sourceMap": true,
    "declaration": false,
    "types": ["node"]
  }
}
