# Public runtime configuration (exposed to the browser — never put secrets here)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudinary (dashboard image uploads). Create an UNSIGNED upload preset in your
# Cloudinary dashboard (Settings → Upload) and put its name + your cloud name here.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
