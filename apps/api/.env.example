# ---- Server ----
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:3000

# ---- Logging ----
# one of: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Database (Homebrew PostgreSQL 18; port 5433 — see README "Database setup") ----
# Use 5432 instead if that is where your Postgres listens.
# Either provide a full DATABASE_URL...
# DATABASE_URL=postgres://riz:riz_local_dev@localhost:5433/riz_perfume
# ...or the individual fields below:
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=riz
DB_PASSWORD=riz_local_dev
DB_NAME=riz_perfume
DB_SSL=false

# ---- Auth ----
# Access token is a stateless JWT; refresh token is opaque + stored (hashed) in DB.
# Generate strong secrets in production, e.g.: openssl rand -base64 48
JWT_ACCESS_SECRET=dev-only-access-secret-change-me-please
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me-please
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_COOKIE_NAME=riz_refresh_token
BCRYPT_ROUNDS=12

# ---- Initial admin (used by `pnpm --filter @riz/api seed:admin`) ----
ADMIN_EMAIL=admin@rizperfume.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULLNAME=Riz Admin
ADMIN_PHONE=+8801700000000
