# ---- Server ----
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:3000

# ---- Logging ----
# one of: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Database (local Homebrew PostgreSQL) ----
# Either provide a full DATABASE_URL...
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/riz_perfume
# ...or the individual fields below:
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=riz_perfume
DB_SSL=false
